# ============================================================================
# HYRO Cloud — Environment Configuration
# Copy to `.env` and fill in. Never commit `.env`.
# ============================================================================

# ---- Runtime ---------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# ---- HYRO Cloud API --------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8080
# Public base URL the CLI / SDK / web dashboard talk to.
PUBLIC_API_URL=http://localhost:8080

# ---- Security --------------------------------------------------------------
# 32+ byte random strings. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string-min-32-bytes
API_KEY_PEPPER=change-me-to-another-long-random-string
# Comma-separated allowed origins for CORS (web dashboard, etc.)
CORS_ORIGINS=http://localhost:3000,http://localhost:4173

# ---- PostgreSQL (pgvector) -------------------------------------------------
DATABASE_URL=postgres://hyro:hyro@localhost:5432/hyro
# Connection pool sizing
PG_POOL_MAX=10
PG_POOL_IDLE_TIMEOUT_MS=30000

# ---- Redis -----------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---- Rate limiting ---------------------------------------------------------
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute

# ---- Model Providers -------------------------------------------------------
# Provide keys for the providers you want enabled. The API and CLI both read
# these. Leave blank to disable a provider. Embeddings fall back to a local
# deterministic encoder when no provider key is present (good for local dev).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Xiaomi MiMo (OpenAI-compatible)
MIMO_API_KEY=
XIAOMI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_API_MODEL=mimo-v2.5-pro

# Default model used when a user has not pinned one.
DEFAULT_MODEL=claude-sonnet-4-6

# Embedding model + dimension (must match the pgvector column dimension).
EMBEDDING_MODEL=local-minilm
EMBEDDING_DIM=1536

# ---- Billing / usage (optional) --------------------------------------------
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
FREE_TIER_MONTHLY_TOKENS=2000000

# ---- MCP runtime -----------------------------------------------------------
# Directory where installed MCP server manifests are cached.
MCP_REGISTRY_URL=https://registry.hyro.cloud
MCP_SANDBOX=true
