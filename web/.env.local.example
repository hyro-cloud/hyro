# Copy to web/.env.local — NEVER commit real keys to git.
# Set the same variables in Vercel → Project → Settings → Environment Variables.

# Required for live MiMo chat in Playground (/api/playground/chat)
MIMO_API_KEY=
XIAOMI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_API_MODEL=mimo-v2.5-pro

# Base RPC for Playground MCP tools (balance, token reads) — NOT used by /token (Token Studio has its own RPC per network).
# Sepolia (B20 testnet):  https://sepolia.base.org
# Mainnet (production):   https://mainnet.base.org
# Omit to default to mainnet in playground tools.
BASE_RPC_URL=https://sepolia.base.org

# Optional — defaults to https://api.hyrocloud.lol
# HYRO_API_URL=https://api.hyrocloud.lol

# Optional — Bankr x402 Cloud CLI (deploy paid endpoints)
# BANKR_API_KEY=

# Optional — x402 facilitator / pay-to wallet for VPS MCP monetization
# X402_PAY_TO_WALLET=
# X402_FACILITATOR_URL=

# Marketplace REAL payments (/marketplace Buy) + send_transaction on server.
# When set, buying a LIVE listing pays real USDC via x402 using this wallet.
# Use a DEDICATED hot wallet with a small USDC balance. Never commit it.
# Leave empty to keep the marketplace in sandbox mode (no funds move).
# WALLET_PRIVATE_KEY=
#
# NOTE ON BASE_RPC_URL (no conflict): the marketplace does NOT use BASE_RPC_URL.
# x402 payments are signed off-chain and the seller's endpoint decides the network
# (base or base-sepolia), so you can keep BASE_RPC_URL on Sepolia for the Playground.
# To test the marketplace for FREE: deploy your Bankr endpoint on base-sepolia and
# fund this wallet with testnet USDC. For real revenue: deploy on Base mainnet.
#
# Optional safety cap — never pay more than this many USDC for a single call:
# MARKETPLACE_MAX_USDC=0.10
#
# Your Bankr wallet — makes the 10 official HYRO skill listings point at YOUR
# deployed endpoints (https://x402.bankr.bot/<wallet>/<slug>). Deploy each slug on
# Bankr, then those listings go live automatically.
# HYRO_X402_WALLET=0xYourBankrWallet
