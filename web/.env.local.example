# Copy to web/.env.local — NEVER commit real keys to git.
# Set the same variables in Vercel → Project → Settings → Environment Variables.

# Required for live MiMo chat in Playground (/api/playground/chat)
MIMO_API_KEY=
XIAOMI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_API_MODEL=mimo-v2.5-pro

# Base RPC for Playground MCP tools (balance, token reads) — NOT used by /token (Token Studio has its own RPC per network).
# Sepolia (B20 testnet):  https://sepolia.base.org
# Mainnet (production):   https://mainnet.base.org
# Omit to default to mainnet in playground tools.
BASE_RPC_URL=https://sepolia.base.org

# Optional — defaults to https://api.hyrocloud.lol
# HYRO_API_URL=https://api.hyrocloud.lol

# Optional — Bankr x402 Cloud CLI (deploy paid endpoints)
# BANKR_API_KEY=

# Optional — x402 facilitator / pay-to wallet for VPS MCP monetization
# X402_PAY_TO_WALLET=
# X402_FACILITATOR_URL=

# Optional — only if you want send_transaction on server (not recommended on Vercel; use VPS CLI)
# WALLET_PRIVATE_KEY=
