{
  "name": "hyro",
  "version": "0.1.0",
  "description": "HYRO Cloud CLI — the terminal for autonomous agents. Deploy. Connect. Remember. Execute.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "hyro": "bin/hyro.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "bin"],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/bin.ts",
    "start": "node dist/bin.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"import('node:fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\""
  },
  "keywords": ["hyro", "ai", "agents", "cli", "mcp", "terminal", "llm", "ink"],
  "dependencies": {
    "@hyro/core": "*",
    "@hyro/sdk": "*",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
