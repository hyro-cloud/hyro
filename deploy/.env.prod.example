# ============================================================================
# Production secrets for VPS (docker-compose.api.yml or docker-compose.prod.yml).
#
# FIRST TIME ONLY:
#   cp deploy/.env.prod.example .env.prod   && nano .env.prod
#
# IF .env.prod ALREADY EXISTS — DO NOT cp AGAIN (it overwrites your secrets).
#   nano .env.prod   # edit in place
#
# Full step-by-step (Indonesian): deploy/PANDUAN-VPS.md
#   Generate secrets:  openssl rand -hex 32
# ============================================================================

# Required — the API refuses to boot in production with insecure defaults.
JWT_SECRET=replace-with-openssl-rand-hex-32
API_KEY_PEPPER=replace-with-another-openssl-rand-hex-32
POSTGRES_PASSWORD=replace-with-a-strong-db-password

# HYRO registry model id (NOT the MiMo API name). Always use mimo-chat for MiMo.
DEFAULT_MODEL=mimo-chat

# ---- Xiaomi MiMo (OpenAI-compatible) ---------------------------------------
MIMO_API_KEY=your-mimo-api-key-here
XIAOMI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
# Model name sent to the MiMo API (from your MiMo dashboard — e.g. mimo or mimo-v2.5-pro):
MIMO_API_MODEL=mimo-v2.5-pro

# ---- Optional other providers ------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ---- MCP (passed into API container for MCP stdio servers) -----------------
GITHUB_TOKEN=
BASE_RPC_URL=https://mainnet.base.org
# Optional — only for onchain txs (Base / B20). Use a dedicated hot wallet.
WALLET_PRIVATE_KEY=

# ---- Official Base MCP OAuth (mcp.base.org) --------------------------------
BASE_MCP_URL=https://mcp.base.org
MCP_OAUTH_SUCCESS_URL=https://hyrocloud.lol/mcp
# Optional — leave empty to auto-register via OAuth DCR on first connect
BASE_MCP_CLIENT_ID=
