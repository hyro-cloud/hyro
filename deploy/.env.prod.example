# ============================================================================
# Production secrets for VPS (docker-compose.api.yml or docker-compose.prod.yml).
#   cp deploy/.env.prod.example .env.prod   && edit   (NEVER commit .env.prod)
#   Generate secrets:  openssl rand -hex 32
# ============================================================================

# Required — the API refuses to boot in production with insecure defaults.
JWT_SECRET=replace-with-openssl-rand-hex-32
API_KEY_PEPPER=replace-with-another-openssl-rand-hex-32
POSTGRES_PASSWORD=replace-with-a-strong-db-password

# Default model (use mimo-chat when running Xiaomi MiMo)
DEFAULT_MODEL=mimo-chat

# ---- Xiaomi MiMo (OpenAI-compatible) ---------------------------------------
MIMO_API_KEY=your-mimo-api-key-here
XIAOMI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
# Model name as expected by the MiMo API (check your MiMo dashboard/docs):
MIMO_API_MODEL=mimo

# ---- Optional other providers ------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
