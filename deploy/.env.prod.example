# ============================================================================
# Production secrets for the VPS stack (docker-compose.prod.yml).
#   cp deploy/.env.prod.example .env.prod  &&  edit values  (NEVER commit .env.prod)
#   Generate secrets:  openssl rand -hex 32
# ============================================================================

# Required — the API refuses to boot in production with insecure defaults.
JWT_SECRET=replace-with-openssl-rand-hex-32
API_KEY_PEPPER=replace-with-another-openssl-rand-hex-32
POSTGRES_PASSWORD=replace-with-a-strong-db-password

# Default model + provider keys (leave blank to use the offline local runtime)
DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
